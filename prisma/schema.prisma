generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(BUYER)

  expertProfile  ExpertProfile?
  bookings       Booking[]       @relation("BuyerBookings")
  reviews        Review[]
  savedExperts   SavedExpert[]
  buyerSettings  BuyerSettings?
  notifications  Notification[]
  adminAuditLogs AdminAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([email])
  @@index([createdAt])
}

enum UserRole {
  BUYER
  EXPERT
  ADMIN
}

model ExpertProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  headline  String
  bio       String
  country   String?
  timezone  String
  languages String[] @default([])
  skills    String[] @default([])
  tags      String[] @default([])

  status ExpertStatus @default(PENDING)

  isVerified       Boolean   @default(false)
  verifiedAt       DateTime?
  verificationNote String?
  rejectedReason   String?
  suspendedReason  String?

  rating        Float @default(0)
  totalReviews  Int   @default(0)
  totalSessions Int   @default(0)

  stripeAccountId        String?   @unique
  stripeChargesEnabled   Boolean   @default(false)
  stripePayoutsEnabled   Boolean   @default(false)
  stripeDetailsSubmitted Boolean   @default(false)
  stripeOnboardingDoneAt DateTime?

  services     Service[]
  availability Availability[]
  bookings     Booking[]      @relation("ExpertBookings")
  reviews      Review[]
  savedBy      SavedExpert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([status, isVerified])
  @@index([isVerified])
  @@index([rating])
  @@index([totalReviews])
  @@index([totalSessions])
  @@index([createdAt])
  @@index([country])
}

enum ExpertStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  icon        String?
  isActive    Boolean @default(true)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([createdAt])
}

model Service {
  id       String        @id @default(cuid())
  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  title           String
  description     String
  durationMinutes Int
  priceCents      Int
  currency        String  @default("EUR")
  isActive        Boolean @default(true)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expertId])
  @@index([categoryId])
  @@index([isActive])
  @@index([priceCents])
  @@index([durationMinutes])
  @@index([createdAt])
  @@index([expertId, isActive])
}

model Availability {
  id String @id @default(cuid())

  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  startTime DateTime
  endTime   DateTime

  /// Availability is now a bookable time window.
  /// Example: helper is available from 10:00 to 14:00.
  /// Buyers can book smaller calls inside this window.
  isActive Boolean @default(true)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expertId])
  @@index([startTime])
  @@index([endTime])
  @@index([isActive])
  @@index([expertId, isActive])
  @@index([expertId, startTime])
  @@index([expertId, startTime, endTime])
}

model Booking {
  id String @id @default(cuid())

  buyerId String
  buyer   User   @relation("BuyerBookings", fields: [buyerId], references: [id], onDelete: Cascade)

  expertId String
  expert   ExpertProfile @relation("ExpertBookings", fields: [expertId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  availabilityId String?
  availability   Availability? @relation(fields: [availabilityId], references: [id], onDelete: SetNull)

  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(PENDING)

  expiresAt   DateTime?
  paidAt      DateTime?
  confirmedAt DateTime?
  cancelledAt DateTime?
  completedAt DateTime?
  refundedAt  DateTime?
  disputedAt  DateTime?

  cancelReason  String?
  disputeReason String?
  disputeNote   String?

  priceCents Int
  currency   String @default("EUR")

  platformFeeCents      Int?
  providerNetCents      Int?
  clientServiceFeeCents Int?
  clientTotalCents      Int?

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique
  stripeChargeId          String?
  stripeRefundId          String?

  review   Review?
  callRoom CallRoom?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([expertId])
  @@index([serviceId])
  @@index([availabilityId])
  @@index([status])
  @@index([expiresAt])
  @@index([startTime])
  @@index([endTime])
  @@index([createdAt])
  @@index([buyerId, status])
  @@index([expertId, status])
  @@index([expertId, startTime])
  @@index([expertId, startTime, endTime])
  @@index([expertId, status, startTime])
  @@index([availabilityId, status, startTime])
  @@index([status, expiresAt])
  @@index([status, startTime])
}

enum BookingStatus {
  PENDING
  PAID
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
  EXPIRED
}

model Review {
  id String @id @default(cuid())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  buyerId String
  buyer   User   @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  rating          Int
  helpfulness     Int?
  clarity         Int?
  professionalism Int?
  wouldRecommend  Boolean?
  comment         String?

  createdAt DateTime @default(now())

  @@index([buyerId])
  @@index([expertId])
  @@index([rating])
  @@index([createdAt])
}

model CallRoom {
  id String @id @default(cuid())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  provider String         @default("JITSI")
  roomName String
  roomUrl  String
  status   CallRoomStatus @default(CREATED)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startsAt])
  @@index([createdAt])
}

enum CallRoomStatus {
  CREATED
  LIVE
  ENDED
}

model SavedExpert {
  id String @id @default(cuid())

  buyerId String
  buyer   User   @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([buyerId, expertId])
  @@index([buyerId])
  @@index([expertId])
  @@index([createdAt])
}

model BuyerSettings {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferredTimezone  String?
  preferredLanguages String[] @default([])
  interests          String[] @default([])

  budgetMinCents Int?
  budgetMaxCents Int?

  defaultReminderMin Int     @default(30)
  hideEmail          Boolean @default(true)
  allowReminders     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model AdminAuditLog {
  id String @id @default(cuid())

  adminId    String?
  adminEmail String?

  action     String
  entityType String
  entityId   String?

  message  String?
  metadata Json?

  createdAt DateTime @default(now())

  admin User? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model Notification {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  email String?

  type    NotificationType
  subject String
  message String

  metadata Json?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  BOOKING_CREATED
  PAYMENT_CONFIRMED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  BOOKING_REFUNDED
  BOOKING_DISPUTED
  BOOKING_PENDING_PAYMENT
  BOOKING_EXPIRED
  CALL_CREATED
  CALL_COMPLETED
  REVIEW_REQUESTED
  REVIEW_RECEIVED
  EXPERT_APPROVED
  EXPERT_REJECTED
  EXPERT_SUSPENDED
  SYSTEM
}

model StripeEvent {
  id          String    @id
  type        String
  processed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([type])
  @@index([processed])
  @@index([createdAt])
}
