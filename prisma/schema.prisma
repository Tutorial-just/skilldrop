generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(BUYER)

  expertProfile ExpertProfile?
  bookings      Booking[] @relation("BuyerBookings")
  reviews       Review[]
  savedExperts  SavedExpert[]
  adminAuditLogs AdminAuditLog[]
  buyerSettings BuyerSettings?
  notifications  Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  BUYER
  EXPERT
  ADMIN
}

model ExpertProfile {
  id          String @id @default(cuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id])

  headline    String
  bio         String
  country     String?
  timezone    String
  languages   String[]
  skills      String[]
  tags      String[] @default([])
  status      ExpertStatus @default(PENDING)

  isVerified       Boolean   @default(false)
  verifiedAt       DateTime?
  verificationNote String?

  rating        Float @default(0)
  totalReviews  Int   @default(0)
  totalSessions Int   @default(0)

  stripeAccountId String?

  services     Service[]
  availability Availability[]
  bookings     Booking[] @relation("ExpertBookings")
  reviews      Review[]
  savedBy SavedExpert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ExpertStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  icon        String?
  isActive    Boolean @default(true)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id              String @id @default(cuid())
  expertId        String
  expert          ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])

  title           String
  description     String
  durationMinutes Int
  priceCents      Int
  currency        String @default("EUR")
  isActive        Boolean @default(true)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Availability {
  id        String @id @default(cuid())

  expertId  String
  expert    ExpertProfile @relation(fields: [expertId], references: [id])

  startTime DateTime
  endTime   DateTime
  isBooked  Boolean @default(false)

  booking   Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id        String @id @default(cuid())

  buyerId   String
  buyer     User @relation("BuyerBookings", fields: [buyerId], references: [id])

  expertId  String
  expert    ExpertProfile @relation("ExpertBookings", fields: [expertId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  availabilityId String?
  availability   Availability? @relation(fields: [availabilityId], references: [id])

  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(PENDING)

  expiresAt DateTime?
  disputeReason String?
  disputeNote   String?
  disputedAt    DateTime?

  priceCents Int
  currency   String @default("EUR")

  stripeCheckoutSessionId String?

  review   Review?
  callRoom CallRoom?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  PAID
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

model Review {
  id        String @id @default(cuid())

  bookingId String @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  buyerId String
  buyer   User @relation(fields: [buyerId], references: [id])

  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id])

  rating          Int
  helpfulness     Int?
  clarity         Int?
  professionalism Int?
  wouldRecommend  Boolean?
  comment         String?

  createdAt DateTime @default(now())
}
model CallRoom {
  id        String         @id @default(cuid())
  bookingId String        @unique
  booking   Booking       @relation(fields: [bookingId], references: [id])

  provider  String        @default("DAILY")
  roomName  String
  roomUrl   String
  status    CallRoomStatus @default(CREATED)

  startsAt  DateTime?
  endsAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CallRoomStatus {
  CREATED
  LIVE
  ENDED
}
model SavedExpert {
  id       String @id @default(cuid())

  buyerId  String
  buyer    User @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([buyerId, expertId])
}
model BuyerSettings {
  id     String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferredTimezone  String?
  preferredLanguages String[] @default([])
  interests          String[] @default([])

  budgetMinCents Int?
  budgetMaxCents Int?

  defaultReminderMin Int     @default(30)
  hideEmail          Boolean @default(true)
  allowReminders     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model AdminAuditLog {
  id String @id @default(cuid())

  adminId    String?
  adminEmail String?

  action     String
  entityType String
  entityId   String?

  message  String?
  metadata Json?

  createdAt DateTime @default(now())

  admin User? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}
model Notification {
  id String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  email String?

  type    String
  subject String
  message String

  metadata Json?

  isRead Boolean @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}