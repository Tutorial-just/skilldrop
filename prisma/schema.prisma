generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(BUYER)

  expertProfile    ExpertProfile?
  bookings         Booking[]         @relation("BuyerBookings")
  reviews          Review[]
  savedExperts     SavedExpert[]
  buyerSettings    BuyerSettings?
  notifications    Notification[]
  adminAuditLogs   AdminAuditLog[]
  bookingReports   BookingReport[]
  categoryRequests CategoryRequest[]
  buyerCallOutcomes CallOutcome[] @relation("BuyerCallOutcomes")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([email])
  @@index([createdAt])
}

enum UserRole {
  BUYER
  EXPERT
  ADMIN
}

model ExpertProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  headline  String
  bio       String
  country   String?
  timezone  String
  languages String[] @default([])
  skills    String[] @default([])
  tags      String[] @default([])

  status ExpertStatus @default(PENDING)

  isVerified       Boolean   @default(false)
  verifiedAt       DateTime?
  verificationNote String?
  rejectedReason   String?
  suspendedReason  String?

  rating        Float @default(0)
  totalReviews  Int   @default(0)
  totalSessions Int   @default(0)

  stripeAccountId        String?   @unique
  stripeChargesEnabled   Boolean   @default(false)
  stripePayoutsEnabled   Boolean   @default(false)
  stripeDetailsSubmitted Boolean   @default(false)
  stripeOnboardingDoneAt DateTime?

  services     Service[]
  availability Availability[]
  bookings     Booking[]      @relation("ExpertBookings")
  reviews      Review[]
  savedBy      SavedExpert[]

  documents ExpertDocument[]
  settings  ExpertSettings?
  expertCallOutcomes CallOutcome[] @relation("ExpertCallOutcomes")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([status, isVerified])
  @@index([isVerified])
  @@index([rating])
  @@index([totalReviews])
  @@index([totalSessions])
  @@index([createdAt])
  @@index([country])
  @@index([status, rating])
  @@index([status, totalSessions])
  @@index([status, createdAt])
  @@index([status, isVerified, rating])
}

enum ExpertStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  icon        String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  subcategories Subcategory[]
  services      Service[]
  requests      CategoryRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([sortOrder])
  @@index([createdAt])
}

model Subcategory {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
  @@index([sortOrder])
  @@index([createdAt])
}

model Service {
  id       String        @id @default(cuid())
  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  helpType HelpType @default(ADVICE)
  tags     String[] @default([])

  title           String
  description     String
  durationMinutes Int
  priceCents      Int
  currency        String  @default("EUR")
  isActive        Boolean @default(true)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expertId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([helpType])
  @@index([isActive])
  @@index([priceCents])
  @@index([durationMinutes])
  @@index([createdAt])
  @@index([expertId, isActive])
  @@index([categoryId, isActive])
  @@index([subcategoryId, isActive])
  @@index([helpType, isActive])
}

model CategoryRequest {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  query         String
  suggestedName String?
  description   String?

  status CategoryRequestStatus @default(PENDING)

  adminNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model Availability {
  id String @id @default(cuid())

  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  startTime DateTime
  endTime   DateTime

  /// Availability is now a bookable time window.
  /// Example: helper is available from 10:00 to 14:00.
  /// Buyers can book smaller calls inside this window.
  isActive Boolean @default(true)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expertId])
  @@index([startTime])
  @@index([endTime])
  @@index([isActive])
  @@index([expertId, isActive])
  @@index([expertId, startTime])
  @@index([expertId, startTime, endTime])
  @@index([isActive, startTime])
  @@index([expertId, isActive, startTime])
}

model Booking {
  id String @id @default(cuid())

  buyerId String
  buyer   User   @relation("BuyerBookings", fields: [buyerId], references: [id], onDelete: Cascade)

  expertId String
  expert   ExpertProfile @relation("ExpertBookings", fields: [expertId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  availabilityId String?
  availability   Availability? @relation(fields: [availabilityId], references: [id], onDelete: SetNull)

  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(PENDING)

  expiresAt   DateTime?
  paidAt      DateTime?
  confirmedAt DateTime?
  cancelledAt DateTime?
  completedAt DateTime?
  refundedAt  DateTime?
  disputedAt  DateTime?

  cancelReason  String?
  disputeReason String?
  disputeNote   String?

  priceCents Int
  currency   String @default("EUR")

  platformFeeCents      Int?
  providerNetCents      Int?
  clientServiceFeeCents Int?
  clientTotalCents      Int?

  stripeCheckoutSessionId String?         @unique
  stripePaymentIntentId   String?         @unique
  stripeChargeId          String?
  stripeRefundId          String?
  reports                 BookingReport[]
  review                  Review?
  callRoom                CallRoom?
  outcome                 CallOutcome?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([expertId])
  @@index([serviceId])
  @@index([availabilityId])
  @@index([status])
  @@index([expiresAt])
  @@index([startTime])
  @@index([endTime])
  @@index([createdAt])
  @@index([buyerId, status])
  @@index([expertId, status])
  @@index([expertId, startTime])
  @@index([expertId, startTime, endTime])
  @@index([expertId, status, startTime])
  @@index([availabilityId, status, startTime])
  @@index([status, expiresAt])
  @@index([status, startTime])
  @@index([buyerId, startTime])
  @@index([buyerId, status, startTime])
  @@index([buyerId, updatedAt])
  @@index([expertId, updatedAt])
  @@index([status, createdAt])
  @@index([createdAt, status])
}

enum BookingStatus {
  PENDING
  PAID
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
  EXPIRED
}

model Review {
  id String @id @default(cuid())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  buyerId String
  buyer   User   @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  rating          Int
  helpfulness     Int?
  clarity         Int?
  professionalism Int?
  wouldRecommend  Boolean?
  problemSolved   String?
  comment         String?

  createdAt DateTime @default(now())

  @@index([buyerId])
  @@index([expertId])
  @@index([rating])
  @@index([createdAt])
  @@index([expertId, createdAt])
  @@index([buyerId, createdAt])
  @@index([rating, createdAt])
  @@index([wouldRecommend, createdAt])
  @@index([problemSolved, createdAt])
}

model CallRoom {
  id String @id @default(cuid())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  provider String         @default("JITSI")
  roomName String
  roomUrl  String
  status   CallRoomStatus @default(CREATED)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startsAt])
  @@index([createdAt])
}

model CallOutcome {
  id String @id @default(cuid())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  buyerId String
  buyer   User @relation("BuyerCallOutcomes", fields: [buyerId], references: [id], onDelete: Cascade)

  expertId String
  expert   ExpertProfile @relation("ExpertCallOutcomes", fields: [expertId], references: [id], onDelete: Cascade)

  problemSummary String
  discussionNotes String?
  nextSteps String
  usefulLinks String[] @default([])

  followUpRecommended Boolean @default(false)
  followUpNote        String?

  isVisibleToBuyer Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([buyerId])
  @@index([expertId])
  @@index([createdAt])
  @@index([buyerId, createdAt])
  @@index([expertId, createdAt])
}

enum CallRoomStatus {
  CREATED
  LIVE
  ENDED
}

model SavedExpert {
  id String @id @default(cuid())

  buyerId String
  buyer   User   @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([buyerId, expertId])
  @@index([buyerId])
  @@index([expertId])
  @@index([createdAt])
}

model BuyerSettings {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferredTimezone  String?
  preferredLanguages String[] @default([])
  interests          String[] @default([])

  budgetMinCents Int?
  budgetMaxCents Int?

  defaultReminderMin Int     @default(30)
  hideEmail          Boolean @default(true)
  allowReminders     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model ExpertSettings {
  id String @id @default(cuid())

  expertId String        @unique
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  bookingEmails Boolean @default(true)
  callReminders Boolean @default(true)
  reviewAlerts  Boolean @default(true)
  weeklySummary Boolean @default(false)

  profileVisible    Boolean @default(true)
  showAvailability  Boolean @default(true)
  showStartingPrice Boolean @default(true)
  showLanguages     Boolean @default(true)

  autoConfirmBookings   Boolean @default(false)
  allowSameDayBookings  Boolean @default(true)
  minimumNoticeMinutes  Int     @default(120)
  bufferBetweenCallsMin Int     @default(10)

  hideEmailFromBuyers Boolean @default(true)
  requireBuyerMessage Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expertId])
}

model AdminAuditLog {
  id String @id @default(cuid())

  adminId    String?
  adminEmail String?

  action     String
  entityType String
  entityId   String?

  message  String?
  metadata Json?

  createdAt DateTime @default(now())

  admin User? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model Notification {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  email String?

  type    NotificationType
  subject String
  message String

  metadata Json?

  isRead    Boolean   @default(false)
  readAt    DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([userId, isRead, createdAt])
  @@index([email, isRead, createdAt])
  @@index([type, createdAt])
}

enum NotificationType {
  BOOKING_CREATED
  PAYMENT_CONFIRMED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  BOOKING_REFUNDED
  BOOKING_DISPUTED
  BOOKING_PENDING_PAYMENT
  BOOKING_EXPIRED
  CALL_CREATED
  CALL_COMPLETED
  REVIEW_REQUESTED
  REVIEW_RECEIVED
  EXPERT_APPROVED
  EXPERT_REJECTED
  EXPERT_SUSPENDED
  SYSTEM
}

model StripeEvent {
  id          String    @id
  type        String
  processed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([type])
  @@index([processed])
  @@index([createdAt])
}

model BookingReport {
  id         String   @id @default(cuid())
  bookingId  String
  reporterId String
  reason     String
  message    String?
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reporter User    @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([reporterId])
  @@index([status])
  @@index([status, createdAt])
  @@index([bookingId, status])
  @@index([reporterId, createdAt])
}

model ExpertDocument {
  id String @id @default(cuid())

  expertId String
  expert   ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  type      ExpertDocumentType
  title     String
  fileUrl   String
  fileName  String?
  mimeType  String?
  sizeBytes Int?

  createdAt DateTime @default(now())

  @@index([expertId])
  @@index([type])
  @@index([createdAt])
}

enum ExpertDocumentType {
  CV
  PORTFOLIO
}

enum HelpType {
  ADVICE
  EXPLANATION
  TEACHING
  PRACTICAL_GUIDANCE
  PERSONAL_EXPERIENCE
  EMOTIONAL_SUPPORT
  RELIGIOUS_DISCUSSION
  BUSINESS_MENTORING
  OTHER
}

enum CategoryRequestStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}
